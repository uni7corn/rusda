diff --git a/lib/base/obfuscate.vala b/lib/base/obfuscate.vala
new file mode 100644
index 0000000..5665e80
--- /dev/null
+++ b/lib/base/obfuscate.vala
@@ -0,0 +1,25 @@
+namespace Frida {
+	/**
+	 * 运行时解码特征字符串，避免二进制中出现 frida 相关字面量，规避内存扫描。
+	 * 支持 XOR / Base58 等编码，可替换实现。
+	 */
+	namespace Obfuscate {
+		private const uint8 XOR_KEY = 0x55;
+
+		/**
+		 * 从 hex 编码的 XOR 密文解码字符串。
+		 * 编译期仅保留 hex 字面量，运行时还原真实字符串。
+		 */
+		public static string decode_hex_xor (string hex) {
+			var len = hex.length / 2;
+			var sb = new StringBuilder.sized (len);
+			for (var i = 0; i < len; i++) {
+				int64 val;
+				int64.try_parse (hex.substring (i * 2, 2), out val, null, 16);
+				var b = (uint8) val;
+				sb.append_c ((char) (b ^ XOR_KEY));
+			}
+			return sb.str;
+		}
+	}
+}
